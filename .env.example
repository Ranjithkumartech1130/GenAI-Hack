# ============================================
# SkillGPS - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# === Gemini AI API Key ===
GEMINI_API_KEY=your_gemini_api_key_here

# === LiveKit (for voice features) ===
LIVEKIT_API_SECRET=your_livekit_secret_here

# === Backend Server ===
PORT=5001
AI_SERVICE_URL=http://127.0.0.1:8002

# === AI Service ===
AI_PORT=8002
